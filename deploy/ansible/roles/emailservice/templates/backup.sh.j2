#!/bin/bash
# Email Service Backup Script
# Generated by Ansible

set -e

BACKUP_DIR="{{ app_dir }}/backup"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_NAME="emailservice_backup_${TIMESTAMP}"
RETENTION_DAYS=30

echo "=== Email Service Backup Started at $(date) ==="

# Create backup directory
mkdir -p "${BACKUP_DIR}/${BACKUP_NAME}"

# Backup mail storage
echo "Backing up mail storage..."
tar -czf "${BACKUP_DIR}/${BACKUP_NAME}/mail-storage.tar.gz" \
  -C "{{ data_dir }}" .

# Backup configuration
echo "Backing up configuration..."
cp "{{ app_dir }}/config.yaml" "${BACKUP_DIR}/${BACKUP_NAME}/"
cp "{{ app_dir }}/docker-compose.yml" "${BACKUP_DIR}/${BACKUP_NAME}/"
cp "{{ app_dir }}/.env" "${BACKUP_DIR}/${BACKUP_NAME}/" || true

# Backup PostgreSQL database
echo "Backing up PostgreSQL database..."
docker exec mail-postgres pg_dump -U {{ postgres_user }} {{ postgres_db }} | \
  gzip > "${BACKUP_DIR}/${BACKUP_NAME}/postgres_dump.sql.gz"

# Backup Redis data
echo "Backing up Redis data..."
docker exec mail-redis redis-cli SAVE
docker cp mail-redis:/data/dump.rdb "${BACKUP_DIR}/${BACKUP_NAME}/redis_dump.rdb"

# Create backup archive
echo "Creating backup archive..."
cd "${BACKUP_DIR}"
tar -czf "${BACKUP_NAME}.tar.gz" "${BACKUP_NAME}"
rm -rf "${BACKUP_NAME}"

# Calculate backup size
BACKUP_SIZE=$(du -h "${BACKUP_NAME}.tar.gz" | cut -f1)
echo "Backup created: ${BACKUP_NAME}.tar.gz (${BACKUP_SIZE})"

# Remove old backups
echo "Removing backups older than ${RETENTION_DAYS} days..."
find "${BACKUP_DIR}" -name "emailservice_backup_*.tar.gz" -mtime +${RETENTION_DAYS} -delete

# List current backups
echo "Current backups:"
ls -lh "${BACKUP_DIR}"/emailservice_backup_*.tar.gz 2>/dev/null || echo "No backups found"

echo "=== Email Service Backup Completed at $(date) ==="
