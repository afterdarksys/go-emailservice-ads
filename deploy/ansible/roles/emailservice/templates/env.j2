# Email Service Environment Variables

# Application
APP_ENV={{ deployment_env }}
EMAIL_DOMAIN={{ email_domain }}

# Ports
SMTP_PORT={{ smtp_port }}
SUBMISSION_PORT={{ submission_port }}
SMTPS_PORT={{ smtps_port }}
IMAP_PORT={{ imap_port }}
IMAPS_PORT={{ imaps_port }}
API_PORT={{ api_port }}
GRPC_PORT={{ grpc_port }}

# Database
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}

# Paths
DATA_DIR={{ data_dir }}
LOG_DIR={{ log_dir }}
CERTS_DIR={{ certs_dir }}

{% if sso_enabled %}
# SSO Configuration
ADS_CLIENT_ID={{ vault_ads_client_id | default('') }}
ADS_CLIENT_SECRET={{ vault_ads_client_secret | default('') }}
{% endif %}

{% if elasticsearch_enabled %}
# Elasticsearch
ES_API_KEY={{ vault_es_api_key | default('') }}
{% endif %}
